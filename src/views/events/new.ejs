<section class="mx-auto max-w-5xl space-y-6">
  <header class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 bg-gradient-to-r from-emerald-50 via-white to-sky-50 px-5 py-6 sm:px-8 sm:py-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-emerald-700">Organizer workspace</p>
          <h1 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl">Create Event</h1>
          <p class="mt-3 text-base leading-7 text-slate-600">
            Draft an event with the details members will see once it is published.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 text-sm">
          <span class="rounded-full bg-emerald-100 px-3 py-1.5 font-semibold text-emerald-800 ring-1 ring-emerald-200">
            Draft by default
          </span>
          <span class="rounded-full bg-amber-100 px-3 py-1.5 font-semibold text-amber-800 ring-1 ring-amber-200">
            Private until published
          </span>
        </div>
      </div>
    </div>
  </header>

  <%- include("partials/create-event-form", { session, fieldErrors, formError, formValues }) %>
</section>
