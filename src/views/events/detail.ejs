<%
  const startDate = new Date(event.startDatetime);
  const endDate = new Date(event.endDatetime);
  const startDatetimeIso = startDate.toISOString();
  const statusClass =
    event.status === "published"
      ? "bg-emerald-100 text-emerald-800 ring-emerald-200"
      : event.status === "draft"
        ? "bg-amber-100 text-amber-800 ring-amber-200"
        : event.status === "cancelled"
          ? "bg-rose-100 text-rose-800 ring-rose-200"
          : "bg-slate-100 text-slate-700 ring-slate-200";
%>

<section id="event-content" class="space-y-6">
  <header class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="bg-gradient-to-r from-sky-50 via-white to-emerald-50 px-5 py-6 sm:px-8 sm:py-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-3xl">
          <div class="flex flex-wrap items-center gap-3">
            <p class="text-sm font-semibold text-sky-700">Event detail</p>
            <span class="rounded-full px-3 py-1 text-xs font-semibold capitalize ring-1 <%= statusClass %>">
              <%= event.status %>
            </span>
          </div>
          <h1 class="mt-3 text-3xl font-bold text-slate-950 sm:text-4xl"><%= event.title %></h1>
          <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600"><%= event.description %></p>
        </div>

        <dl class="grid gap-4 border-t border-slate-200 pt-5 text-sm text-slate-600 sm:grid-cols-2 lg:min-w-72 lg:grid-cols-1 lg:border-l lg:border-t-0 lg:pl-6 lg:pt-0">
          <div>
            <dt class="font-semibold text-slate-800">Organizer</dt>
            <dd class="mt-1 text-base text-slate-950"><%= event.organizerDisplayName %></dd>
          </div>
          <div>
            <dt class="font-semibold text-slate-800">Attendance</dt>
            <dd class="mt-1 text-base text-slate-950">
              <%- include("partials/attendance-summary", { event }) %>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </header>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr),minmax(280px,1fr)]">
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
      <h2 class="text-xl font-semibold text-slate-900">Event Details</h2>
      <dl class="mt-5 divide-y divide-slate-100">
        <div class="py-4 first:pt-0 sm:grid sm:grid-cols-[8rem_minmax(0,1fr)] sm:gap-4">
          <dt class="text-sm font-semibold text-slate-500">Category</dt>
          <dd class="mt-1 text-base text-slate-950 sm:mt-0"><%= event.category %></dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-[8rem_minmax(0,1fr)] sm:gap-4">
          <dt class="text-sm font-semibold text-slate-500">Location</dt>
          <dd class="mt-1 text-base text-slate-950 sm:mt-0"><%= event.location %></dd>
        </div>
        <div
          class="py-4 sm:grid sm:grid-cols-[8rem_minmax(0,1fr)] sm:gap-4"
          x-data="{
            relativeStartTime: '',
            updateRelativeStartTime() {
              const start = new Date('<%= startDatetimeIso %>');
              const diffMs = start.getTime() - Date.now();
              const absMs = Math.abs(diffMs);
              const units = [
                ['year', 31536000000],
                ['month', 2592000000],
                ['week', 604800000],
                ['day', 86400000],
                ['hour', 3600000],
                ['minute', 60000],
              ];
              const selected = units.find(([, ms]) => absMs >= ms) || units[units.length - 1];
              const value = Math.round(diffMs / selected[1]);
              this.relativeStartTime = new Intl.RelativeTimeFormat(undefined, { numeric: 'auto' }).format(value, selected[0]);
            }
          }"
          x-init="updateRelativeStartTime()"
        >
          <dt class="text-sm font-semibold text-slate-500">Starts</dt>
          <dd class="mt-1 flex flex-col gap-2 text-base text-slate-950 sm:mt-0">
            <time datetime="<%= startDatetimeIso %>"><%= startDate.toLocaleString() %></time>
            <span
              x-show="relativeStartTime"
              x-text="relativeStartTime"
              class="w-fit rounded-full bg-sky-100 px-3 py-1 text-sm font-semibold text-sky-800 ring-1 ring-sky-200"
            ></span>
          </dd>
        </div>
        <div class="py-4 last:pb-0 sm:grid sm:grid-cols-[8rem_minmax(0,1fr)] sm:gap-4">
          <dt class="text-sm font-semibold text-slate-500">Ends</dt>
          <dd class="mt-1 text-base text-slate-950 sm:mt-0"><%= endDate.toLocaleString() %></dd>
        </div>
      </dl>
    </article>

    <aside class="space-y-4">
      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
        <h2 class="text-xl font-semibold text-slate-900">Action Area</h2>
        <%- include("partials/rsvp-action-area", { event }) %>
      </section>

      <% const canLoadAttendees =
        session?.authenticatedUser &&
        (
          session.authenticatedUser.role === "admin" ||
          session.authenticatedUser.userId === event.organizerId
        ); %>
      <% if (canLoadAttendees) { %>
        <section
          class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6"
          x-data="{ attendeesOpen: false }"
          x-on:keydown.escape.window="attendeesOpen = false"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-sky-700">Organizer tools</p>
              <h2 class="mt-1 text-xl font-semibold text-slate-900">Attendees</h2>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                View RSVP details grouped by status.
              </p>
            </div>
            <div class="shrink-0">
              <button
                type="button"
                class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                hx-get="/events/<%= event.id %>/attendees"
                hx-target="#attendee-list-container"
                hx-swap="innerHTML"
                @click="attendeesOpen = true"
                :aria-expanded="attendeesOpen.toString()"
                aria-controls="attendee-list-container"
                aria-label="View attendee list"
                x-show="!attendeesOpen"
              >
                View attendee list
              </button>
              <button
                type="button"
                class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
                @click="attendeesOpen = false"
                :aria-expanded="attendeesOpen.toString()"
                aria-controls="attendee-list-container"
                aria-label="Hide attendee list"
                x-show="attendeesOpen"
                x-cloak
              >
                Hide attendee list
              </button>
            </div>
          </div>
          <div class="mt-4 flex items-center gap-3">
            <a
              href="/events/<%= event.id %>/attendees"
              class="text-sm font-medium text-blue-700 no-underline hover:underline"
            >
              Open full page
            </a>
          </div>
          <div
            id="attendee-list-container"
            class="mt-4 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-4"
            role="region"
            :aria-hidden="(!attendeesOpen).toString()"
            aria-live="polite"
            x-show="attendeesOpen"
            x-cloak
          >
            <p class="text-sm text-slate-500">Click “View attendee list” to load attendee details.</p>
          </div>
        </section>
      <% } %>

      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
        <h2 class="text-xl font-semibold text-slate-900">Visibility</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Draft events are visible only to their organizer and to admins. Published
          events are visible to any authenticated user.
        </p>
      </section>
    </aside>
  </div>
</section>
