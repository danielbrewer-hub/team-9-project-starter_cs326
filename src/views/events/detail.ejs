<%
  const startDate = new Date(event.startDatetime);
  const endDate = new Date(event.endDatetime);
  const attendeeSummary = typeof event.capacity === "number"
    ? `${event.attendeeCount} / ${event.capacity} attending`
    : `${event.attendeeCount} attending`;
%>

<section class="space-y-6">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-[0.18em] text-slate-500">Feature 2</p>
        <h1 class="mt-2 text-4xl font-bold text-slate-900"><%= event.title %></h1>
        <p class="mt-4 text-base leading-7 text-slate-600"><%= event.description %></p>
      </div>
      <div class="flex flex-col items-start gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-600">
        <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-white">
          <%= event.status %>
        </span>
        <div>
          <p class="font-semibold text-slate-800">Organizer</p>
          <p><%= event.organizerDisplayName %></p>
        </div>
        <div>
          <p class="font-semibold text-slate-800">Attendance</p>
          <p><%= attendeeSummary %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr),minmax(280px,1fr)]">
    <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
      <h2 class="text-xl font-semibold text-slate-900">Event Details</h2>
      <dl class="mt-5 grid gap-5 sm:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Category</dt>
          <dd class="mt-2 text-base text-slate-900"><%= event.category %></dd>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Location</dt>
          <dd class="mt-2 text-base text-slate-900"><%= event.location %></dd>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Starts</dt>
          <dd class="mt-2 text-base text-slate-900"><%= startDate.toLocaleString() %></dd>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Ends</dt>
          <dd class="mt-2 text-base text-slate-900"><%= endDate.toLocaleString() %></dd>
        </div>
      </dl>
    </article>

    <aside class="space-y-4">
      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
        <h2 class="text-xl font-semibold text-slate-900">Action Area</h2>
        <div class="mt-4 space-y-3 text-sm text-slate-600">
          <% if (event.canEdit) { %>
            <%/* Feature 3 — GET /events/:id/edit renders the edit-form.ejs partial */%>
            <a
              href="/events/<%= event.id %>/edit"
              class="block w-full rounded-2xl border border-slate-200 bg-slate-900 px-4 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-slate-700"
            >
              Edit Event
            </a>
          <% } %>

          <% if (event.canEdit && event.status === "draft") { %>
            <%/* Feature 5 — POST /events/:id/publish transitions draft → published */%>
            <form action="/events/<%= event.id %>/publish" method="POST">
              <button
                type="submit"
                class="w-full rounded-2xl border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700 transition-colors hover:bg-emerald-100"
              >
                Publish Event
              </button>
            </form>
          <% } %>

          <% if (event.canCancel) { %>
            <%/* Feature 5 — POST /events/:id/cancel transitions draft|published → cancelled */%>
            <form
              action="/events/<%= event.id %>/cancel"
              method="POST"
              onsubmit="return confirm('Are you sure you want to cancel this event? This cannot be undone.');"
            >
              <button
                type="submit"
                class="w-full rounded-2xl border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700 transition-colors hover:bg-red-100"
              >
                Cancel Event
              </button>
            </form>
          <% } %>


          <% if (event.canRsvp) { %>
            <div class="rounded-2xl border border-blue-200 bg-blue-50 px-4 py-3">
              RSVP actions will appear here when the RSVP flow is implemented.
            </div>
          <% } %>

          <% if (!event.canEdit && !event.canCancel && !event.canRsvp) { %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
              No direct actions are available for your role on this event yet.
            </div>
          <% } %>
        </div>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
        <h2 class="text-xl font-semibold text-slate-900">Visibility</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Draft events are visible only to their organizer and to admins. Published
          events are visible to any authenticated user.
        </p>
      </section>
    </aside>
  </div>
</section>
