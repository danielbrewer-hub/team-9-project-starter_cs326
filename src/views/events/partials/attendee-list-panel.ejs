<section
  class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg"
  aria-labelledby="attendee-list-heading"
>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <h2 id="attendee-list-heading" class="text-xl font-semibold text-slate-900">Attendee list</h2>
    <button
      type="button"
      class="inline-flex items-center justify-center rounded-lg bg-slate-800 px-4 py-2 text-sm font-semibold text-white shadow transition hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2"
      hx-get="/events/<%= event.id %>/attendees"
      hx-target="#event-attendee-list"
      hx-swap="innerHTML"
    >
      Load RSVPs
    </button>
  </div>
  <p class="mt-2 text-xs text-slate-500">
    Loads everyone who has RSVPed, grouped by attending, waitlisted, and cancelled — without reloading the page.
  </p>
  <div id="event-attendee-list" class="mt-4 min-h-[1rem] text-sm text-slate-600">
    <p class="text-slate-500">Click the button above to load the list.</p>
  </div>
</section>
