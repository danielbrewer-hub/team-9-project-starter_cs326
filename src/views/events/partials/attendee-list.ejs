<section id="attendee-list" class="space-y-4">
  <h2 class="text-xl font-semibold text-slate-900">Attendee List</h2>

  <% const groups = [
    { key: "going", label: "Attending" },
    { key: "waitlisted", label: "Waitlisted" },
    { key: "cancelled", label: "Cancelled" },
  ]; %>

  <% groups.forEach((group) => { const rows = attendeeList.attendees[group.key]; %>
    <article class="rounded-2xl border border-slate-200 bg-white p-4">
      <h3 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600">
        <%= group.label %> (<%= rows.length %>)
      </h3>
      <% if (rows.length === 0) { %>
        <p class="mt-2 text-sm text-slate-500">No attendees in this status yet.</p>
      <% } else { %>
        <ul class="mt-3 space-y-2">
          <% rows.forEach((attendee) => { %>
            <li class="flex items-center justify-between rounded-xl border border-slate-100 bg-slate-50 px-3 py-2">
              <span class="font-medium text-slate-900"><%= attendee.displayName %></span>
              <time class="text-xs text-slate-500"><%= new Date(attendee.rsvpCreatedAt).toLocaleString() %></time>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </article>
  <% }); %>
</section>
