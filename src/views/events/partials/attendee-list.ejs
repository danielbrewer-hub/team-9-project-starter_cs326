<section id="attendee-list" class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">RSVP roster</p>
      <h2 class="mt-1 text-xl font-semibold text-slate-950">Attendee List</h2>
      <p class="mt-2 text-sm text-slate-600">Grouped by RSVP status and ordered by response time.</p>
    </div>
  </div>

  <% const groups = [
    {
      key: "going",
      label: "Attending",
      accent: "border-emerald-200 bg-emerald-50",
      badge: "bg-emerald-100 text-emerald-800 ring-emerald-200",
      empty: "text-emerald-700",
    },
    {
      key: "waitlisted",
      label: "Waitlisted",
      accent: "border-amber-200 bg-amber-50",
      badge: "bg-amber-100 text-amber-800 ring-amber-200",
      empty: "text-amber-700",
    },
    {
      key: "cancelled",
      label: "Cancelled",
      accent: "border-rose-200 bg-rose-50",
      badge: "bg-rose-100 text-rose-800 ring-rose-200",
      empty: "text-rose-700",
    },
  ]; %>

  <div class="space-y-4">
  <% groups.forEach((group) => { const rows = attendeeList.attendees[group.key]; %>
    <article class="overflow-hidden rounded-2xl border shadow-sm <%= group.accent %>">
      <header class="flex items-center justify-between gap-3 border-b border-white/70 px-4 py-3.5 sm:px-5">
        <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-700">
          <%= group.label %>
        </h3>
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= group.badge %>">
          <%= rows.length %>
        </span>
      </header>
      <% if (rows.length === 0) { %>
        <p class="px-4 py-4 text-sm font-medium sm:px-5 <%= group.empty %>">No attendees in this status yet.</p>
      <% } else { %>
        <ul class="divide-y divide-slate-200/70 bg-white">
          <% rows.forEach((attendee) => { %>
            <li class="grid gap-1 px-4 py-3.5 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center sm:gap-3 sm:px-5">
              <span class="font-medium text-slate-950"><%= attendee.displayName %></span>
              <time class="text-xs font-medium text-slate-600 sm:text-right" datetime="<%= new Date(attendee.rsvpCreatedAt).toISOString() %>">
                RSVPed on <%= new Date(attendee.rsvpCreatedAt).toLocaleString() %>
              </time>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </article>
  <% }); %>
  </div>
</section>
