<%
  const startDate = new Date(event.startDatetime);
  const endDate   = new Date(event.endDatetime);
  const attendeeSummary = typeof event.capacity === "number"
    ? `${event.attendeeCount} / ${event.capacity} attending`
    : `${event.attendeeCount} attending`;

  const pad = (n) => String(n).padStart(2, "0");
  const fmt = (d) =>
    `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
%>

<form
  class="space-y-6"
  hx-put="/events/<%= event.id %>/edit"
  hx-target="#event-content"
  hx-swap="innerHTML"
>

  <!-- ===== "Feature 2" banner — title & description become inputs ===== -->
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-3xl w-full">
        <p class="text-sm uppercase tracking-[0.18em] text-slate-500">Feature 2</p>

        <input
          name="title"
          type="text"
          value="<%= event.title %>"
          required
          class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2
                 text-4xl font-bold text-slate-900
                 focus:border-blue-500 focus:outline-none"
        />

        <textarea
          name="description"
          rows="3"
          required
          class="mt-4 w-full rounded-lg border border-slate-300 px-3 py-2
                 text-base leading-7 text-slate-600
                 focus:border-blue-500 focus:outline-none"
        ><%= event.description %></textarea>
      </div>

      <!-- Status / Organizer / Attendance — read-only -->
      <div class="flex flex-col items-start gap-3 rounded-2xl border border-slate-200
                  bg-slate-50 px-4 py-4 text-sm text-slate-600">
        <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold
                     uppercase tracking-[0.16em] text-white">
          <%= event.status %>
        </span>
        <div>
          <p class="font-semibold text-slate-800">Organizer</p>
          <p><%= event.organizerDisplayName %></p>
        </div>
        <div>
          <p class="font-semibold text-slate-800">Attendance</p>
          <p><%= attendeeSummary %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Grid ===== -->
  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr),minmax(280px,1fr)]">

    <!-- Event Details — each value becomes an input -->
    <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
      <h2 class="text-xl font-semibold text-slate-900">Event Details</h2>

      <dl class="mt-5 grid gap-5 sm:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Category</dt>
          <dd class="mt-2">
            <input name="category" type="text" value="<%= event.category %>" required
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-base
                     text-slate-900 focus:border-blue-500 focus:outline-none" />
          </dd>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Location</dt>
          <dd class="mt-2">
            <input name="location" type="text" value="<%= event.location %>" required
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-base
                     text-slate-900 focus:border-blue-500 focus:outline-none" />
          </dd>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Starts</dt>
          <dd class="mt-2">
            <input name="startDatetime" type="datetime-local" value="<%= fmt(startDate) %>"
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-base
                     text-slate-900 focus:border-blue-500 focus:outline-none" />
          </dd>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Ends</dt>
          <dd class="mt-2">
            <input name="endDatetime" type="datetime-local" value="<%= fmt(endDate) %>"
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-base
                     text-slate-900 focus:border-blue-500 focus:outline-none" />
          </dd>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <dt class="text-sm font-semibold text-slate-500">Capacity</dt>
          <dd class="mt-2">
            <input name="capacity" type="number" value="<%= event.capacity %>"
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-base
                     text-slate-900 focus:border-blue-500 focus:outline-none" />
          </dd>
        </div>
      </dl>
    </article>

    <!-- Sidebar — Save / Cancel replace the Action Area -->
    <aside class="space-y-4">
      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
        <h2 class="text-xl font-semibold text-slate-900">Edit Actions</h2>
        <div class="mt-4 space-y-3">
          <button type="submit"
            class="w-full rounded-lg bg-blue-600 px-4 py-2 text-white
                   font-semibold shadow hover:bg-blue-700 focus:outline-none">
            Save Changes
          </button>
          <button type="button"
            hx-get="/events/<%= event.id %>"
            hx-target="#event-content"
            hx-swap="innerHTML"
            class="w-full rounded-lg border border-slate-300 px-4 py-2
                   text-slate-700 font-semibold shadow hover:bg-slate-50
                   focus:outline-none">
            Cancel
          </button>
        </div>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg">
        <h2 class="text-xl font-semibold text-slate-900">Visibility</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Draft events are visible only to their organizer and to admins. Published
          events are visible to any authenticated user.
        </p>
      </section>
    </aside>
  </div>
</form>