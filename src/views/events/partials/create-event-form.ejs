<div
  id="event-create-panel"
  aria-live="polite"
  class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-8"
>
  <% if (formError) { %>
    <div class="mb-6">
      <%- include("../../partials/error", { message: formError }) %>
    </div>
  <% } %>

  <form
    method="post"
    action="/events"
    hx-post="/events"
    hx-target="#event-create-panel"
    hx-swap="outerHTML"
    x-data="{
      dateRangeTouched: false,
      startDatetimeError: '',
      dateRangeError: '',
      currentDatetimeLocal() {
        const now = new Date();
        const pad = (value) => String(value).padStart(2, '0');
        return now.getFullYear() + '-' +
          pad(now.getMonth() + 1) + '-' +
          pad(now.getDate()) + 'T' +
          pad(now.getHours()) + ':' +
          pad(now.getMinutes());
      },
      validateDateRange(touched = false) {
        if (touched) {
          this.dateRangeTouched = true;
        }

        const startInput = this.$refs.startDatetime;
        const endInput = this.$refs.endDatetime;

        if (!startInput || !endInput) {
          return;
        }

        const now = this.currentDatetimeLocal();
        const start = startInput.value;
        const end = endInput.value;
        startInput.min = now;
        endInput.min = start;

        if (start && start <= now) {
          this.startDatetimeError = 'Start time must be in the future.';
          startInput.setCustomValidity(this.startDatetimeError);
        } else {
          this.startDatetimeError = '';
          startInput.setCustomValidity('');
        }

        if (start && end && end <= start) {
          this.dateRangeError = 'End time must be after the start time.';
          endInput.setCustomValidity(this.dateRangeError);
        } else {
          this.dateRangeError = '';
          endInput.setCustomValidity('');
        }
      }
    }"
    x-init="$nextTick(() => validateDateRange())"
    class="space-y-7"
  >
    <div class="grid gap-5 md:grid-cols-2">
      <label class="block">
        <span class="block text-sm font-semibold text-slate-700">Title</span>
        <input
          type="text"
          name="title"
          required
          aria-invalid="<%= fieldErrors?.title ? 'true' : 'false' %>"
          value="<%= formValues?.title ?? '' %>"
          class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
        />
        <% if (fieldErrors?.title) { %>
          <p class="mt-2 text-sm text-red-600"><%= fieldErrors.title %></p>
        <% } %>
      </label>

      <label class="block">
        <span class="block text-sm font-semibold text-slate-700">Category</span>
        <input
          type="text"
          name="category"
          required
          aria-invalid="<%= fieldErrors?.category ? 'true' : 'false' %>"
          value="<%= formValues?.category ?? '' %>"
          class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
        />
        <% if (fieldErrors?.category) { %>
          <p class="mt-2 text-sm text-red-600"><%= fieldErrors.category %></p>
        <% } %>
      </label>
    </div>

    <label class="block">
      <span class="block text-sm font-semibold text-slate-700">Description</span>
      <textarea
        name="description"
        rows="5"
        required
        aria-invalid="<%= fieldErrors?.description ? 'true' : 'false' %>"
        class="mt-2 min-h-36 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
      ><%= formValues?.description ?? '' %></textarea>
      <% if (fieldErrors?.description) { %>
        <p class="mt-2 text-sm text-red-600"><%= fieldErrors.description %></p>
      <% } %>
    </label>

    <div class="grid gap-5 md:grid-cols-2">
      <label class="block">
        <span class="block text-sm font-semibold text-slate-700">Location</span>
        <input
          type="text"
          name="location"
          required
          aria-invalid="<%= fieldErrors?.location ? 'true' : 'false' %>"
          value="<%= formValues?.location ?? '' %>"
          class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
        />
        <% if (fieldErrors?.location) { %>
          <p class="mt-2 text-sm text-red-600"><%= fieldErrors.location %></p>
        <% } %>
      </label>

      <label class="block">
        <span class="block text-sm font-semibold text-slate-700">Capacity</span>
        <input
          type="number"
          min="1"
          step="1"
          name="capacity"
          aria-invalid="<%= fieldErrors?.capacity ? 'true' : 'false' %>"
          value="<%= formValues?.capacity ?? '' %>"
          class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
        />
        <p class="mt-2 text-sm text-slate-500">Leave blank for no capacity limit.</p>
        <% if (fieldErrors?.capacity) { %>
          <p class="mt-2 text-sm text-red-600"><%= fieldErrors.capacity %></p>
        <% } %>
      </label>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      <label class="block">
        <span class="block text-sm font-semibold text-slate-700">Start Time</span>
        <input
          type="datetime-local"
          name="startDatetime"
          required
          x-ref="startDatetime"
          @input="validateDateRange(true)"
          @change="validateDateRange(true)"
          aria-invalid="<%= fieldErrors?.startDatetime ? 'true' : 'false' %>"
          data-server-invalid="<%= fieldErrors?.startDatetime ? 'true' : 'false' %>"
          :aria-invalid="startDatetimeError ? 'true' : $el.dataset.serverInvalid"
          value="<%= formValues?.startDatetime ?? '' %>"
          class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
        />
        <% if (fieldErrors?.startDatetime) { %>
          <p class="mt-2 text-sm text-red-600" x-show="!dateRangeTouched"><%= fieldErrors.startDatetime %></p>
        <% } %>
        <p
          x-show="dateRangeTouched && startDatetimeError"
          x-text="startDatetimeError"
          class="mt-2 text-sm text-red-600"
          aria-live="polite"
        ></p>
      </label>

      <label class="block">
        <span class="block text-sm font-semibold text-slate-700">End Time</span>
        <input
          type="datetime-local"
          name="endDatetime"
          required
          x-ref="endDatetime"
          @input="validateDateRange(true)"
          @change="validateDateRange(true)"
          aria-invalid="<%= fieldErrors?.endDatetime ? 'true' : 'false' %>"
          data-server-invalid="<%= fieldErrors?.endDatetime ? 'true' : 'false' %>"
          :aria-invalid="dateRangeError ? 'true' : $el.dataset.serverInvalid"
          value="<%= formValues?.endDatetime ?? '' %>"
          class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-950 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-100"
        />
        <% if (fieldErrors?.endDatetime) { %>
          <p class="mt-2 text-sm text-red-600" x-show="!dateRangeTouched"><%= fieldErrors.endDatetime %></p>
        <% } %>
        <p
          x-show="dateRangeTouched && dateRangeError"
          x-text="dateRangeError"
          class="mt-2 text-sm text-red-600"
          aria-live="polite"
        ></p>
      </label>
    </div>

    <div class="flex flex-col gap-4 border-t border-slate-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-slate-500">
        Logged in as <strong class="text-slate-700"><%= session?.authenticatedUser?.displayName %></strong>.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/home"
          class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 no-underline transition hover:bg-slate-100"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-lg border border-emerald-700 bg-emerald-700 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-800 focus:outline-none focus:ring-4 focus:ring-emerald-100"
        >
          Save Draft Event
        </button>
      </div>
    </div>
  </form>
</div>
