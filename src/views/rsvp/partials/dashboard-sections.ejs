<%
  function rsvpCardTransitionName(rsvpId) {
    return `rsvp-card-${String(rsvpId).replace(/[^a-zA-Z0-9_-]/g, "-")}`;
  }
%>

<section
  id="rsvp-dashboard-sections"
  hx-get="/rsvp/partials/sections"
  hx-trigger="rsvp-dashboard-refresh from:body"
  hx-swap="outerHTML transition:true"
  class="grid gap-5"
>
  <div class="space-y-5">
    <section class="overflow-hidden rounded-2xl border border-blue-200 bg-white shadow-lg">
      <div class="border-b border-blue-100 bg-blue-50 px-6 py-5">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-xl font-semibold text-blue-950 mb-1">Upcoming RSVPs</h2>
            <p class="text-blue-800">Events you plan to attend or are currently waitlisted for.</p>
          </div>
          <span class="inline-flex items-center rounded-full bg-blue-600 text-white px-3 py-1 text-sm font-semibold shadow-sm">
            <%= (dashboard?.upcomingRsvps?.length ?? 0) %> events
          </span>
        </div>
      </div>

      <div class="p-6">
        <% if ((dashboard?.upcomingRsvps?.length ?? 0) === 0) { %>
          <p class="rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-blue-800">You have no upcoming RSVPs at the moment.</p>
        <% } else { %>
          <div class="space-y-4">
            <% for (const rsvp of dashboard.upcomingRsvps) { %>
              <article
                id="rsvp-dashboard-item-<%= rsvp.id %>"
                class="rounded-2xl border border-blue-100 bg-white p-5 shadow-sm ring-1 ring-blue-50 transition hover:border-blue-200 hover:shadow-md [view-transition-name:var(--rsvp-card-transition)]"
                style="--rsvp-card-transition: <%= rsvpCardTransitionName(rsvp.id) %>;"
                x-data="{ confirming: false, confirmed: false, submitting: false }"
              >
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="space-y-3">
                    <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
                      <span
                        class="rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wide <%= rsvp.rsvpStatus === 'going' ? 'bg-emerald-100 text-emerald-800' : rsvp.rsvpStatus === 'waitlisted' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-700' %>"
                      >
                        <%= rsvp.rsvpStatus %>
                      </span>
                      <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= rsvp.category %></span>
                      <span><%= rsvp.location %></span>
                    </div>
                    <h3 class="text-lg font-semibold text-slate-900">
                      <a
                        href="/events/<%= rsvp.eventId %>"
                        class="text-slate-900 no-underline hover:text-blue-700 hover:underline"
                      >
                        <%= rsvp.title %>
                      </a>
                    </h3>
                    <p class="text-sm text-slate-600"><%= rsvp.dateLabel %> · <%= rsvp.timeLabel %></p>
                  </div>

                  <div class="flex flex-col items-start gap-3 sm:items-end">
                    <span class="text-sm text-slate-500">RSVP status: <strong class="capitalize text-slate-900"><%= rsvp.rsvpStatus %></strong></span>
                    <a
                      href="/events/<%= rsvp.eventId %>"
                      class="text-sm font-semibold text-blue-700 no-underline hover:underline"
                    >
                      View details
                    </a>
                    <form
                      method="post"
                      action="/rsvp/<%= rsvp.id %>/cancel"
                      hx-post="/events/<%= rsvp.eventId %>/rsvp/toggle"
                      hx-swap="none"
                      hx-headers='{"HX-RSVP-Dashboard":"true"}'
                      class="m-0 w-full sm:w-auto"
                      x-on:submit="if (!confirmed) { $event.preventDefault(); confirming = true; } else { submitting = true; }"
                    >
                      <button
                        type="submit"
                        class="inline-flex w-full items-center justify-center rounded-lg bg-red-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-800 focus:outline-none focus:ring-4 focus:ring-red-200 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
                        x-bind:disabled="submitting"
                        x-show="!confirming"
                        x-transition.opacity.duration.200ms
                      >
                        Cancel RSVP
                      </button>

                      <div
                        class="rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-900"
                        x-cloak
                        x-show="confirming"
                        x-transition.opacity.duration.200ms
                        style="display: none;"
                      >
                        <p class="mb-3 font-semibold">Cancel this RSVP?</p>
                        <div class="flex flex-wrap gap-2">
                          <button
                            type="submit"
                            class="inline-flex items-center justify-center rounded-lg bg-red-700 px-3 py-2 text-sm font-semibold text-white transition hover:bg-red-800 focus:outline-none focus:ring-4 focus:ring-red-200 disabled:cursor-not-allowed disabled:opacity-60"
                            x-on:click="confirmed = true"
                            x-bind:disabled="submitting"
                          >
                            Confirm
                          </button>
                          <button
                            type="button"
                            class="inline-flex items-center justify-center rounded-lg border border-red-200 bg-white px-3 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100 focus:outline-none focus:ring-4 focus:ring-red-100"
                            x-on:click="confirming = false; confirmed = false"
                          >
                            Keep RSVP
                          </button>
                        </div>
                      </div>
                    </form>
                  </div>
                </div>
              </article>
            <% } %>
          </div>
        <% } %>
      </div>
    </section>

    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg">
      <div class="border-b border-slate-200 bg-slate-100 px-6 py-5">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-xl font-semibold text-slate-900 mb-1">Past & Cancelled RSVPs</h2>
            <p class="text-slate-600">Events you previously attended, skipped, or cancelled.</p>
          </div>
          <span class="inline-flex items-center rounded-full bg-slate-700 px-3 py-1 text-sm font-semibold text-white">
            <%= (dashboard?.pastRsvps?.length ?? 0) %> events
          </span>
        </div>
      </div>

      <div class="p-6">
        <% if ((dashboard?.pastRsvps?.length ?? 0) === 0) { %>
          <p class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-600">No past or cancelled RSVP history is available yet.</p>
        <% } else { %>
          <div class="space-y-4">
            <% for (const rsvp of dashboard.pastRsvps) { %>
              <article
                id="rsvp-dashboard-item-<%= rsvp.id %>"
                class="rounded-2xl border border-slate-200 bg-slate-50 p-5 [view-transition-name:var(--rsvp-card-transition)]"
                style="--rsvp-card-transition: <%= rsvpCardTransitionName(rsvp.id) %>;"
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div class="space-y-2">
                    <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
                      <span
                        class="rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wide <%= rsvp.rsvpStatus === 'cancelled' ? 'bg-rose-100 text-rose-800' : rsvp.rsvpStatus === 'waitlisted' ? 'bg-amber-100 text-amber-800' : 'bg-slate-200 text-slate-700' %>"
                      >
                        <%= rsvp.rsvpStatus %>
                      </span>
                      <span class="rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-slate-700 ring-1 ring-slate-200"><%= rsvp.eventStatus %></span>
                    </div>
                    <h3 class="text-lg font-semibold text-slate-900"><%= rsvp.title %></h3>
                    <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
                      <span><%= rsvp.dateLabel %></span>
                      <span>·</span>
                      <span><%= rsvp.location %></span>
                    </div>
                  </div>
                  <span class="text-sm font-semibold text-slate-600"><%= rsvp.eventStatus %></span>
                </div>
              </article>
            <% } %>
          </div>
        <% } %>
      </div>
    </section>
  </div>
</section>
