<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">
    <%= home?.welcomeTitle ?? "Welcome to Project Starter" %>
  </h1>
  <p class="text-slate-500">
    <%= home?.welcomeMessage ?? "You are signed in and ready to build." %>
  </p>
  <% if (home?.signedInSummary) { %>
    <p class="text-slate-500 mt-2 mb-0">
      Signed in as <strong class="text-slate-700"><%= home.signedInSummary %></strong>.
    </p>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Getting Started</h2>
    <p class="text-slate-500">
      This starter application now shows a full route/controller/service/repository path.
      Here are some next steps:
    </p>
  </div>

  <ul class="list-disc pl-5 space-y-2 text-slate-700">
    <% for (const tip of home?.gettingStartedTips ?? []) { %>
      <li>
        <strong><%= tip.title %>:</strong>
        <%= tip.description %>
      </li>
    <% } %>
  </ul>
</section>

<section class="max-w-3xl mt-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg" x-data="{ open: false }">
  <button
    @click="open = !open"
    class="w-full flex items-center justify-between text-left bg-transparent border-0 p-0 cursor-pointer"
  >
    <h2 class="text-xl font-semibold"><%= home?.alpineDemo.title ?? "Alpine.js Demo" %></h2>
    <span class="text-slate-400 text-sm" x-text="open ? 'Hide' : 'Show'">Show</span>
  </button>

  <div x-show="open" x-transition class="mt-4">
    <p class="text-slate-500 mb-3">
      <%= home?.alpineDemo.description ?? "Alpine.js is included via CDN and ready to use." %>
    </p>
    <div x-data="{ count: 0 }" class="flex items-center gap-3">
      <button
        @click="count++"
        class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 text-sm"
      >
        <%= home?.alpineDemo.buttonLabel ?? "Clicked:" %> <span x-text="count">0</span>
      </button>
      <span class="text-sm text-slate-500">
        <%= home?.alpineDemo.helperText ?? "A simple Alpine.js counter" %>
      </span>
    </div>
  </div>
</section>
