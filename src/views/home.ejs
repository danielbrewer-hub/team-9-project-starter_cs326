<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">
    <%= home?.welcomeTitle ?? "Welcome to Project Starter" %>
  </h1>
  <p class="text-slate-500">
    <%= home?.welcomeMessage ?? "You are signed in and ready to build." %>
  </p>
  <% if (home?.signedInSummary) { %>
    <p class="text-slate-500 mt-2 mb-0">
      Signed in as <strong class="text-slate-700"><%= home.signedInSummary %></strong>.
    </p>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Event Summary</h2>
    <p class="text-slate-500">
      This home page is now backed by event and RSVP records stored in the repository layer.
    </p>
  </div>

  <ul class="list-disc pl-5 space-y-2 text-slate-700">
    <% for (const item of home?.eventSummary ?? []) { %>
      <li><%= item %></li>
    <% } %>
  </ul>
</section>

<%
  const recentEvents = home?.recentEvents ?? [];
  const visibleRecentEvents = recentEvents.slice(0, 5);
  const hiddenRecentEvents = recentEvents.slice(5);
%>

<section class="max-w-3xl mt-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg" x-data="{ showMore: false }">
  <div class="mb-4 flex items-center justify-between gap-4">
    <h2 class="text-xl font-semibold">Recent Events</h2>
    <span class="text-sm text-slate-400"><%= recentEvents.length %> total</span>
  </div>

  <% if (recentEvents.length === 0) { %>
    <p class="text-slate-500 mb-0">No events are stored yet.</p>
  <% } else { %>
    <div class="space-y-3">
      <% for (const event of visibleRecentEvents) { %>
        <article class="rounded-xl border border-slate-200 p-4 bg-slate-50">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-slate-900">
                <a
                  href="/events/<%= event.id %>"
                  class="text-slate-900 no-underline hover:underline"
                >
                  <%= event.title %>
                </a>
              </h3>
              <p class="text-sm text-slate-500 mt-1">
                <%= event.category %> · <%= event.location %>
              </p>
            </div>
            <span class="text-xs uppercase tracking-wide text-slate-500"><%= event.status %></span>
          </div>
          <p class="text-sm text-slate-600 mt-3">
            <%= event.attendeeCount %> confirmed attendee<%= event.attendeeCount === 1 ? "" : "s" %>
          </p>
          <p class="mt-3">
            <a
              href="/events/<%= event.id %>"
              class="text-sm font-semibold text-blue-700 no-underline hover:underline"
            >
              View details
            </a>
          </p>
        </article>
      <% } %>
    </div>

    <% if (hiddenRecentEvents.length > 0) { %>
      <div x-show="showMore" x-transition class="mt-3 space-y-3" style="display: none;">
        <% for (const event of hiddenRecentEvents) { %>
        <article class="rounded-xl border border-slate-200 p-4 bg-slate-50">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-slate-900">
                <a
                  href="/events/<%= event.id %>"
                  class="text-slate-900 no-underline hover:underline"
                >
                  <%= event.title %>
                </a>
              </h3>
              <p class="text-sm text-slate-500 mt-1">
                <%= event.category %> · <%= event.location %>
              </p>
            </div>
            <span class="text-xs uppercase tracking-wide text-slate-500"><%= event.status %></span>
          </div>
          <p class="text-sm text-slate-600 mt-3">
            <%= event.attendeeCount %> confirmed attendee<%= event.attendeeCount === 1 ? "" : "s" %>
          </p>
          <p class="mt-3">
            <a
              href="/events/<%= event.id %>"
              class="text-sm font-semibold text-blue-700 no-underline hover:underline"
            >
              View details
            </a>
          </p>
        </article>
        <% } %>
      </div>

      <button
        type="button"
        @click="showMore = !showMore"
        class="mt-4 inline-flex items-center justify-center rounded-lg border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 transition hover:bg-blue-100 focus:outline-none focus:ring-4 focus:ring-blue-100"
        x-text="showMore ? 'Show fewer' : 'Show more'"
      >
        Show more
      </button>
    <% } %>
  <% } %>
</section>
